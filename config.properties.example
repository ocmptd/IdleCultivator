# QQ 机器人凭据 (https://q.qq.com/)
bot.appid=
bot.token=
bot.secret=

# 是否使用沙箱环境
bot.sandbox=false

# SQLite 数据库文件路径
db.path=idle-cultivator.db

# 图片缓存目录
image.cache.dir=image-cache

# 图片生成 API
image.api.url=https://www.right.codes
image.api.key=
image.api.model=gpt-image-2
image.api.size=1:1
image.api.image-size=1K
image.api.prompt-prefix=Idle Cultivator 指尖修仙 左上角水印.游戏素材,不要有其他无关元素

# 指令前缀,默认 "!";设为空则无前缀(直接输入 修炼/状态 等指令名)
command.prefix=!

# 群消息是否仅在 @ 机器人时触发,默认 false(不 @ 也触发)
# 注意:公域机器人腾讯服务端通常只推送被 @ 的群消息
command.require-at=false
